generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(CASHIER)
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  staffProfile  StaffProfile?
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  CAPTAIN
}

// ─── Restaurant ─────────────────────────────────────────────────────────────

model Restaurant {
  id            String         @id @default(cuid())
  name          String
  address       String?
  phone         String?
  gstin         String?
  logo          String?
  currency      String         @default("INR")
  taxRate       Float          @default(5.0)
  brandColor    String         @default("#f97316")
  tagline       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  users         User[]
  tables        Table[]
  categories    Category[]
  menuItems     MenuItem[]
  orders        Order[]
  inventory     InventoryItem[]
  customers     Customer[]
  staff         StaffProfile[]
  offers        Offer[]
  reservations  Reservation[]
  tableSessions TableSession[]
}

// ─── Tables ─────────────────────────────────────────────────────────────────

model Table {
  id            String         @id @default(cuid())
  number        String
  capacity      Int            @default(4)
  status        TableStatus    @default(AVAILABLE)
  section       String?
  restaurantId  String
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  orders        Order[]
  reservations  Reservation[]
  tableSessions TableSession[]
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

// ─── Menu ────────────────────────────────────────────────────────────────────

model Category {
  id           String     @id @default(cuid())
  name         String
  description  String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]
}

model MenuItem {
  id           String       @id @default(cuid())
  name         String
  description  String?
  price        Float
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  isVeg        Boolean      @default(true)
  isAvailable  Boolean      @default(true)
  image        String?
  taxRate      Float?
  variants     Variant[]
  orderItems   OrderItem[]
  inventoryLinks MenuInventoryLink[]
}

model Variant {
  id         String   @id @default(cuid())
  name       String
  price      Float
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  type         OrderType   @default(DINE_IN)
  status       OrderStatus @default(PENDING)
  tableId      String?
  table        Table?      @relation(fields: [tableId], references: [id])
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  items        OrderItem[]
  payments     Payment[]
  subtotal     Float       @default(0)
  taxAmount    Float       @default(0)
  discount     Float       @default(0)
  total        Float       @default(0)
  notes        String?
  source       OrderSource @default(DIRECT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  reservation  Reservation?
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum OrderSource {
  DIRECT
  ZOMATO
  SWIGGY
  WEBSITE
  PHONE
  TABLE_QR
  PRE_ORDER
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  variantId  String?
  quantity   Int       @default(1)
  price      Float
  notes      String?
  status     KOTStatus @default(PENDING)
}

enum KOTStatus {
  PENDING
  PREPARING
  READY
  SERVED
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])
  method    PaymentMethod
  amount    Float
  reference String?
  createdAt DateTime      @default(now())
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
  OTHER
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model InventoryItem {
  id           String   @id @default(cuid())
  name         String
  unit         String
  quantity     Float    @default(0)
  minQuantity  Float    @default(0)
  costPerUnit  Float    @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuLinks    MenuInventoryLink[]
  updatedAt    DateTime @updatedAt
}

model MenuInventoryLink {
  id              String        @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantityUsed    Float
}

// ─── Staff & Attendance ──────────────────────────────────────────────────────

model StaffProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  designation  String?
  phone        String?
  joinDate     DateTime @default(now())
  salary       Float?
  shiftType    ShiftType @default(FULL_DAY)
  isActive     Boolean  @default(true)
  attendance   AttendanceRecord[]
  leaves       LeaveRequest[]
}

enum ShiftType {
  MORNING
  EVENING
  FULL_DAY
}

model AttendanceRecord {
  id          String           @id @default(cuid())
  staffId     String
  staff       StaffProfile     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date        DateTime
  status      AttendanceStatus
  minutesLate Int              @default(0)
  note        String?
  createdAt   DateTime         @default(now())

  @@unique([staffId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

model LeaveRequest {
  id           String      @id @default(cuid())
  staffId      String
  staff        StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  fromDate     DateTime
  toDate       DateTime
  type         LeaveType
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedBy   String?
  createdAt    DateTime    @default(now())
}

enum LeaveType {
  CASUAL
  SICK
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Ops Monitoring ──────────────────────────────────────────────────────────

model HealthCheck {
  id           String   @id @default(cuid())
  endpoint     String
  status       Int      // HTTP status code
  responseMs   Int      // response time in ms
  ok           Boolean
  error        String?
  checkedAt    DateTime @default(now())

  @@index([endpoint, checkedAt])
}

model ErrorLog {
  id         String   @id @default(cuid())
  endpoint   String
  method     String
  statusCode Int
  message    String?
  occurredAt DateTime @default(now())

  @@index([occurredAt])
}

// ─── OTP Verification ────────────────────────────────────────────────────────

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  data      String   // JSON blob of the setup form data
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Customer {
  id           String     @id @default(cuid())
  name         String
  phone        String
  email        String?
  loyaltyPoints Int       @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  orders       Order[]
  createdAt    DateTime   @default(now())
}

model Lead {
  id             String   @id @default(cuid())
  name           String
  restaurantName String
  email          String
  phone          String
  features       String   // JSON or comma-separated list of selected premium features
  totalPrice     Float
  notes          String?
  createdAt      DateTime @default(now())
}

model Offer {
  id           String       @id @default(cuid())
  title        String
  description  String?
  code         String       @unique
  discountType DiscountType @default(PERCENTAGE)
  value        Float        // percentage rate or flat amount
  minBillAmount Float       @default(0)
  maxDiscount  Float?       // max limit for percentage discounts
  startDate    DateTime     @default(now())
  endDate      DateTime
  isActive     Boolean      @default(true)
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

model Reservation {
  id           String            @id @default(cuid())
  guestName    String
  guestPhone   String
  guestCount   Int
  dateTime     DateTime
  tableId      String?
  table        Table?            @relation(fields: [tableId], references: [id])
  status       ReservationStatus @default(PENDING)
  notes        String?
  restaurantId String
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  orderId      String?           @unique
  order        Order?            @relation(fields: [orderId], references: [id])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
}

// ─── QR Table Sessions (Zero-Trust IDOR Hardening) ──────────────────────────
// Each QR code encodes a session UUID — never a raw table ID.
// Sessions expire after 120 minutes or upon checkout/manual close.
// Steward gives customers a 4-digit PIN to activate ordering on their session.

model TableSession {
  id            String    @id @default(uuid())   // UUIDv4 — embedded in QR URL
  tableId       String
  table         Table     @relation(fields: [tableId], references: [id], onDelete: Cascade)
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  pin           String    // 4-digit PIN shown to steward, customer must enter to activate
  isActivated   Boolean   @default(false) // true after customer enters correct PIN
  createdAt     DateTime  @default(now())
  expiresAt     DateTime  // createdAt + 120 minutes, enforced server-side
  closedAt      DateTime? // set on checkout or staff manual close
  isActive      Boolean   @default(true)

  @@index([tableId])
  @@index([expiresAt])
}
